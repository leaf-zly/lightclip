{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LightClip",
  "version": "2.0.3",
  "identifier": "dev.lightclip.desktop",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://127.0.0.1:4287",
    "beforeDevCommand": "pnpm dev:renderer",
    "beforeBuildCommand": "pnpm build:renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LightClip",
        "width": 860,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: blob:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "publisher": "qiang.tan",
    "resources": [
      "../resources/*"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
